{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DmScream",
  "version": "0.1.0",
  "identifier": "io.github.szynszyl320",
  "build": {
  "frontendDist": "../dist/dndnt/browser", 
  "devUrl": "http://localhost:4200",
  "beforeDevCommand": "ng serve",
  "beforeBuildCommand": "ng build"
},
  "app": {
    "windows": [
      {
        "title": "DmScream",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/main_ico.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
